APP_NAME="SaaS E-Commerce"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

PRODUCT_IMPORT_QUEUE_CONNECTION=database
PRODUCT_IMPORT_ASYNC_IMAGES=true

# ------------------------------------------------------------------
# Payments
# ------------------------------------------------------------------
PAYMENTS_DEFAULT_PROVIDER=stripe
PAYMENTS_DEFAULT_MODE=test

# Stripe test / sandbox platform config
STRIPE_TEST_KEY=pk_test_your_test_publishable_key
STRIPE_TEST_SECRET=sk_test_your_test_secret_key
STRIPE_TEST_WEBHOOK_SECRET=whsec_your_test_platform_webhook_secret
STRIPE_CONNECT_TEST_WEBHOOK_SECRET=whsec_your_test_connect_webhook_secret
STRIPE_CONNECT_TEST_CLIENT_ID=ca_your_test_connect_client_id

# Stripe live platform config
STRIPE_LIVE_KEY=pk_live_your_live_publishable_key
STRIPE_LIVE_SECRET=sk_live_your_live_secret_key
STRIPE_LIVE_WEBHOOK_SECRET=whsec_your_live_platform_webhook_secret
STRIPE_CONNECT_LIVE_WEBHOOK_SECRET=whsec_your_live_connect_webhook_secret
STRIPE_CONNECT_LIVE_CLIENT_ID=ca_your_live_connect_client_id

# Legacy single-mode Stripe env (backward compatible; maps to STRIPE_MODE)
STRIPE_MODE=test
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_REFRESH_URL=
STRIPE_CONNECT_RETURN_URL=
STRIPE_ALLOW_PLATFORM_SANDBOX_FALLBACK=true

# Local/testing only. Never use this as production live Stripe.
STRIPE_LOCAL_MIRROR_TEST_KEYS_FOR_LIVE=false

# ------------------------------------------------------------------
# Carriers — FedEx Model A (primary) / Model B (developer fallback only)
# Model A: platform integrator parent credentials + merchant child credentials via registration.
# Model B: merchant-entered FedEx Developer API keys — temporary fallback for local/dev testing only.
# Never commit real FedEx API secrets.
# ------------------------------------------------------------------
CARRIER_DEFAULT_ENVIRONMENT=sandbox

FEDEX_ENABLED=false
FEDEX_ENVIRONMENT=sandbox
FEDEX_DEFAULT_CONNECTION_MODEL=integrator_provider
FEDEX_DEVELOPER_MODE_ENABLED=false
FEDEX_INTEGRATOR_MODEL_A_ENABLED=true
FEDEX_INTEGRATOR_PRODUCTION_ENABLED=false
FEDEX_MODEL_B_DEVELOPER_FALLBACK_ENABLED=false
# When true only: exposes merchant FedEx Developer credential wizard (Model B). Not for normal SaaS onboarding.
FEDEX_VALIDATION_MODE_ENABLED=false
# Comma-separated scopes for final export preflight (trade_documents optional)
# FEDEX_VALIDATION_REQUIRED_SCOPES=account_registration,address_validation,service_availability,comprehensive_rates,ship,tracking
# FEDEX_BASIC_INTEGRATED_VISIBILITY_PATH=
FEDEX_INTEGRATOR_EULA_VERSION="FedEx Form No. 2002382 v 4 June 2024 Rev"
FEDEX_INTEGRATOR_EULA_PATH=resources/legal/fedex/FedEx_Standard_End_User_License_Agreement_EULA_for_Hosted_3rd_party_solutions.pdf
FEDEX_INTEGRATOR_EULA_FORM_NUMBER=2002382
FEDEX_INTEGRATOR_EULA_EXPECTED_PAGES=11
FEDEX_INTEGRATOR_EULA_SHA256=3eea76a66fbae1d798c2069934ec9c2750c75e8f47879697cec16c84c47e8ab8
# FEDEX_MFA_PIN_GENERATION_PATH=
# FEDEX_MFA_PIN_VALIDATION_PATH=
# FEDEX_MFA_INVOICE_VALIDATION_PATH=
FEDEX_SANDBOX_BASE_URL=https://apis-sandbox.fedex.com
FEDEX_SANDBOX_CLIENT_ID=
FEDEX_SANDBOX_CLIENT_SECRET=
# Must match FedEx Developer Portal Credential Registration API path (default v2 address validation)
FEDEX_SANDBOX_ACCOUNT_REGISTRATION_PATH=/registration/v2/address/keysgeneration

FEDEX_LIVE_BASE_URL=https://apis.fedex.com
FEDEX_LIVE_CLIENT_ID=
FEDEX_LIVE_CLIENT_SECRET=
FEDEX_LIVE_ACCOUNT_REGISTRATION_PATH=/registration/v2/address/keysgeneration
# Optional global override if sandbox/live paths are identical:
# FEDEX_ACCOUNT_REGISTRATION_PATH=
# Diagnostic-only (local/testing): omit | boolean | string — do not send residential to Credential Registration by default
# FEDEX_ACCOUNT_REGISTRATION_RESIDENTIAL_MODE=omit
# Local/testing only: enable sandbox platform OAuth fallback when FedEx Credential Registration is blocked
# FEDEX_SANDBOX_ALLOW_PLATFORM_FALLBACK=false
# FEDEX_ADDRESS_VALIDATION_PATH=/address/v1/addresses/resolve
# FEDEX_SERVICE_AVAILABILITY_PATH=/availability/v1/packageandserviceoptions
# FEDEX_RATE_QUOTE_PATH=/rate/v1/rates/quotes
# FEDEX_COMPREHENSIVE_RATE_PATH=/rate/v1/comprehensiverates/quotes
# FedEx Ship API — sandbox evidence only unless production explicitly enabled
# FEDEX_SHIP_CREATE_PATH=/ship/v1/shipments
# FEDEX_SHIP_VALIDATE_PATH=/ship/v1/shipments/packages/validate
# FEDEX_SHIP_CANCEL_PATH=/ship/v1/shipments/cancel
# FEDEX_TRADE_DOCUMENTS_UPLOAD_PATH=
FEDEX_SHIP_EVIDENCE_ENABLED=false
FEDEX_SHIP_SANDBOX_LABEL_GENERATION_ENABLED=false

# ------------------------------------------------------------------
# Carriers (USPS public API foundation — store real keys in local .env only)
# Never commit USPS API secrets.
# ------------------------------------------------------------------
USPS_ENABLED=false
USPS_ENVIRONMENT=testing
USPS_BASE_URL=https://apis-tem.usps.com
USPS_CONSUMER_KEY=
USPS_CONSUMER_SECRET=
USPS_CRID=
USPS_MASTER_MID=
USPS_LABELER_MID=
USPS_LABELS_ENABLED=false
USPS_PLATFORM_LABEL_PURCHASE=false
USPS_MERCHANT_CONNECTION_ENABLED=false
USPS_PLATFORM_EPA=
USPS_PLATFORM_LABEL_PROVIDER_NAME=BmyBrand
USPS_BUSINESS_PORTAL_URL=https://gateway.usps.com/eAdmin/action/home

# Phase C — Merchant Label Provider OAuth (requires separate Platform Shipping app from USPS)
USPS_MERCHANT_OAUTH_ENABLED=false
USPS_MERCHANT_OAUTH_ICD_CONFIRMED=false
USPS_MERCHANT_COP_AUTHORIZATION_URL=
USPS_MERCHANT_OAUTH_CONSUMER_KEY=
USPS_MERCHANT_OAUTH_CONSUMER_SECRET=
USPS_OAUTH_CALLBACK_PATH=/settings/shipping/carriers/usps/oauth/callback
USPS_OAUTH_REDIRECT_URL=
USPS_MERCHANT_OAUTH_ALLOW_HTTP_REDIRECT=false
# Leave blank to omit scope from authorize requests unless USPS specifies approved scopes
USPS_MERCHANT_OAUTH_SCOPE=
USPS_USERINFO_PATH=/oauth2-oidc/v3/userinfo
USPS_OAUTH_REVOKE_PATH=/oauth2/v3/revoke

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false

# ------------------------------------------------------------------
# Runtime storage retention (CLEAN-3 — disabled by default)
# See docs/operations/RUNTIME_STORAGE_RETENTION.md
# ------------------------------------------------------------------
PROJECT_RETENTION_ENABLED=false
PROJECT_RETENTION_DRY_RUN=true
PROJECT_RETENTION_LOG_DAYS=30
PROJECT_RETENTION_CACHE_HOURS=24
PROJECT_RETENTION_SOURCE_ARCHIVE_COUNT=5
PROJECT_RETENTION_SOURCE_ARCHIVE_DAYS=30
PROJECT_RETENTION_VALIDATION_TEMP_DAYS=14
PROJECT_RETENTION_TEST_ARTIFACT_HOURS=24
PROJECT_RETENTION_SESSION_CLEANUP_ENABLED=false
PROJECT_RETENTION_SCHEDULE_ENABLED=false
PROJECT_RETENTION_SCHEDULE_FREQUENCY=daily
PROJECT_RETENTION_SCHEDULE_FORCE=false
PROJECT_RETENTION_SCHEDULE_CATEGORIES=cache,validation-temp
PROJECT_RETENTION_TEST_SANDBOX_REQUIRED=true
