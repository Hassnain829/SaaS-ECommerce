APP_NAME="SaaS E-Commerce"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

PRODUCT_IMPORT_QUEUE_CONNECTION=database
PRODUCT_IMPORT_ASYNC_IMAGES=true

# Platform payments (Stripe Connect — test/live separation)
PAYMENTS_DEFAULT_PROVIDER=stripe
PAYMENTS_DEFAULT_MODE=test

# Stripe test/sandbox keys (platform + Connect onboarding)
STRIPE_TEST_KEY=
STRIPE_TEST_SECRET=
STRIPE_TEST_WEBHOOK_SECRET=
STRIPE_CONNECT_TEST_WEBHOOK_SECRET=
STRIPE_CONNECT_TEST_CLIENT_ID=

# Stripe live keys (required before live platform checkout)
STRIPE_LIVE_KEY=
STRIPE_LIVE_SECRET=
STRIPE_LIVE_WEBHOOK_SECRET=
STRIPE_CONNECT_LIVE_WEBHOOK_SECRET=
STRIPE_CONNECT_LIVE_CLIENT_ID=

# Legacy single-mode Stripe env (backward compatible; maps to STRIPE_MODE)
STRIPE_MODE=test
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_REFRESH_URL=
STRIPE_CONNECT_RETURN_URL=
STRIPE_ALLOW_PLATFORM_SANDBOX_FALLBACK=true

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
