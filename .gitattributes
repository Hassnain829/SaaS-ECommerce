* text=auto eol=lf

*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

/.github export-ignore
/.git export-ignore
/.cursor export-ignore
/.agents export-ignore
/.phpunit.cache export-ignore
/.phpunit.result.cache export-ignore
/.vscode export-ignore
/.idea export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore

# Real environment files (templates such as .env.example remain included)
.env export-ignore
.env.local export-ignore
.env.production export-ignore
.env.staging export-ignore
.env.backup export-ignore
.env.testing export-ignore
.env.*.local export-ignore
dev-test-storefront/.env export-ignore

vendor export-ignore
